/*
Identify the top 5 most enrolled courses. 
What makes these courses popular among students?
*/
----------------------------------------------------------------------------
with cte_enrolled as (
select 
courseid,
count(studentid) as no_of_student
from Enrollments
group by CourseID)
select top 5
e.courseid,
c.coursename,
e.no_of_student
from cte_enrolled as e
join Courses as c
on e.courseid = c.CourseID
order by  no_of_student desc;
-------------------------------------------------------------------------
/*
Find courses with low enrollment numbers. 
Should these courses be promoted or discontinued?
*/
with cte_enrolled as (
select 
courseid,
count(studentid) as no_of_student
from Enrollments
group by CourseID)
select top 3
e.courseid,
c.coursename,
e.no_of_student
from cte_enrolled as e
join Courses as c
on e.courseid = c.CourseID
order by  no_of_student ;
-------------------------------------------------------------------------
/*
Calculate the average number of credits students are taking per semester.
Is the workload balanced?
*/
-------------------------------------------------------------------------
with cte_avgcredit as (
select
s.studentid,
concat(s.firstname,' ',s.lastname) as fullname,
c.coursename,
c.credits,
case 
when month(e.EnrollmentDate) between 1 and 6 then 'summer'
else 'winter'
end as semester ,
year(e.enrollmentdate) as years
from enrollments as e
join students as s 
on s.studentid =e.studentid
join courses as c
on c.courseid = e.courseid
)
select 
semester,
years,
round(avg(cast(credits as float)),2) as avg_cred
from cte_avgcredit
group by semester,years
order by years,semester;
