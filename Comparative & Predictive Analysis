/*
Analyze whether students enrolled in higher-credit courses tend to achieve better grades
*/
=========================================================================
with cte_high as (
select
1 as link,
round(avg(cast(case 
	        when e.grade ='A' then 4
	        when e.grade ='B' then 3
	        when e.grade ='C' then 2
	        when e.grade ='D' then 1
	        when e.grade ='F' then 0
        end as float)),2)as higher_credit_avg_grade
from Enrollments as e
join students as s
on s.studentid = e.studentid
join courses as c
on c.courseid = e.courseid
where credits = (select top 1
                credits from Courses
                order by Credits desc))
,cte_others_avg as (
select
1 as link ,
round(avg(cast(case 
	        when e.grade ='A' then 4
	        when e.grade ='B' then 3
	        when e.grade ='C' then 2
	        when e.grade ='D' then 1
	        when e.grade ='F' then 0
        end as float)),2)as other_credit_avg_grade
from Enrollments as e
join students as s
on s.studentid = e.studentid
join courses as c
on c.courseid = e.courseid
where credits <> (select top 1
                credits from Courses
                order by Credits desc))
select
ch.higher_credit_avg_grade,
co.other_credit_avg_grade
from cte_high as ch
join cte_others_avg as co
on co.link= ch.link;
