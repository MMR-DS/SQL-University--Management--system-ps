/*
Predict which students are at risk of failing based on their grades and number of courses taken.
*/
=========================================================================
with cte_risk as (
        select 
        e.courseid,
        e.studentid,
        concat(s.FirstName,' ',s.LastName) as fullname,
        c.coursename,
        e.grade,
        year(e.EnrollmentDate) as years,
        case
        when month(e.enrollmentdate) between 1 and 6 then 'Summer'
        else 'Winter'
        end as semster,
        count(*) over(partition by e.studentid) as Total_course_count
        from enrollments as e
        join courses as c
        on c.courseid = e.CourseID
        join students as s
        on s.StudentID =e.StudentID
        ),
cte_fail as (
        select 
        e.studentid,
        concat(s.FirstName,' ',s.LastName) as fullname,
        e.grade,
        count(*) over(partition by e.studentid) as total_failed
        from Enrollments as e
        join Students as s
        on s.StudentID=e.StudentID
        where e.grade = 'F'
        )
select 
cf.studentid,
cf.fullname,
avg(cf.total_failed) as total_fail,
avg(cr.total_course_count) as total_course
from cte_fail as cf
join cte_risk as cr 
on cf.StudentID=cr.StudentID
group by cf.StudentID,cf.fullname
order by total_fail desc ,total_course desc;
