/*
Compare the enrollment growth of different departments over the last three years.
(instead all four semster)
Which department is expanding fastest?*/
=========================================================================

with cte_gradepoint as (
        select 
        e.courseid,
        e.studentid,
        c.coursename,
        e.grade,
        cast(case 
	        when e.grade ='A' then 4
	        when e.grade ='B' then 3
	        when e.grade ='C' then 2
	        when e.grade ='D' then 1
	        when e.grade ='F' then 0
        end as float) as gradepoint,
        year(e.EnrollmentDate) as years,
        case
        when month(e.enrollmentdate) between 1 and 6 then 'Summer'
        else 'Winter'
        end as semster
        from enrollments as e
        join courses as c
        on c.courseid = e.CourseID)
,
cte_c_d_p as (select 
cde.CourseName,
cde.department as departmentid,
pd.professorid,
d.DepartmentName
from cd as cde
join ProfessorDepartments as pd
on pd.departmentid = cde.department
join departments as d
on pd.departmentid = d.DepartmentID
)
select 
cdp.departmentname,
cg.years,
cg.semster,
count(cg.studentid) as total_enrollment_per_deoartment
from cte_gradepoint as cg
join cte_c_d_p as cdp
on cg.CourseName = cdp.CourseName
group by DepartmentName,years,semster
order by DepartmentName,years desc ,semster desc;
